{
  "manifest_version": 3,
  "name": "Markopy",
  "version": "1.0.0",
  "description": "Copy web page content as Markdown format with templates and keyboard shortcuts",

  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting",
    "storage",
    "clipboardWrite",
    "offscreen"
  ],

  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],

  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },

  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },

  "options_page": "src/options/index.html",

  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },

  "commands": {
    "copy-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+M",
        "mac": "Command+Shift+M"
      },
      "description": "Copy selection as Markdown"
    },
    "copy-selection-link": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Copy selection as Markdown link"
    },
    "copy-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Copy page as Markdown"
    },
    "copy-links": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Copy all links as Markdown"
    },
    "quick-action-1": {
      "description": "Markopy quick action 1"
    },
    "quick-action-2": {
      "description": "Markopy quick action 2"
    },
    "quick-action-3": {
      "description": "Markopy quick action 3"
    }
  },

  "web_accessible_resources": [
    {
      "resources": ["src/offscreen/index.html"],
      "matches": ["<all_urls>"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self'"
  }
}
